{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dotnet": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    },
    "angular": {
      "type": "local",
      "command": [
        "pnpx",
        "@angular/cli",
        "mcp"
      ],
      "enabled": true
    },
    "dx": {
      "type": "remote",
      "url": "https://api.devexpress.com/mcp/docs",
      "enabled": true
    },
    "aspire": {
      "type": "local",
      "command": [
        "aspire",
        "agent",
        "mcp"
      ],
      "enabled": true
    }
  }
}
